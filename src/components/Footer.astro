        <ul class="space-y-3 text-gray-300 font-medium">
          <li><a href="/tjanster#motesytor" class="hover:text-sam-cyan transition-colors inline-block">Mötesytor</a></li>
          <li><a href="/tjanster#event" class="hover:text-sam-cyan transition-colors inline-block">Event</a></li>
