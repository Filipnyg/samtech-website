<footer class="bg-sam-blue text-white pt-16 pb-8 border-t-4 border-sam-cyan">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      
      <div>
