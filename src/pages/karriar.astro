---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <header class="bg-sam-blue text-white py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto mt-10">
      <h1 class="text-5xl font-bold mb-6 tracking-tight">Karriär på <span class="text-sam-cyan">SamTech</span></h1>
      <p class="text-xl text-gray-300 font-medium">
        Vi letar alltid efter talanger som brinner för AV-teknik och installationer. Bli en del av vårt team!
      </p>
    </div>
  </header>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="bg-white rounded-3xl p-10 md:p-12 border border-gray-100 shadow-2xl">
      <div class="border-b border-gray-100 pb-6 mb-8">
        <h2 class="text-3xl font-bold text-sam-blue">Skicka in din ansökan</h2>
        <p class="text-sm text-gray-500 mt-2">Fyll i dina uppgifter nedan och bifoga ditt CV så hör vi av oss så fort vi kan.</p>
      </div>

      <form action="https://formspree.io/f/YOUR_FORMSPREE_ID" method="POST" enctype="multipart/form-data" class="space-y-6">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-semibold text-sam-blue mb-2">För- och efternamn *</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium" placeholder="Ex. Anna Andersson" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-sam-blue mb-2">Telefonnummer *</label>
            <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium" placeholder="070-000 00 00" />
          </div>
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-sam-blue mb-2">E-postadress *</label>
          <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium" placeholder="namn@exempel.se" />
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-sam-blue mb-2">Kort presentation</label>
          <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium resize-none" placeholder="Berätta lite kort om dig själv och varför du vill jobba med oss..."></textarea>
        </div>

        <div>
          <label for="resume" class="block text-sm font-semibold text-sam-blue mb-2">Bifoga CV (PDF, Word) *</label>
          <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-sam-blue file:text-white hover:file:bg-sam-cyan transition-all cursor-pointer" />
        </div>

        <div class="flex justify-end pt-4">
          <button type="submit" class="bg-sam-cyan text-white font-bold py-4 px-12 rounded-full hover:bg-sam-blue transition-colors shadow-md focus:outline-none w-full md:w-auto cursor-pointer">
            Skicka ansökan
          </button>
        </div>
        
      </form>
    </div>
  </section>
</Layout>