---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <header class="bg-sam-blue text-white py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto mt-10">
      <h1 class="text-5xl font-bold mb-6 tracking-tight">Teknisk <span class="text-sam-cyan">Support</span></h1>
      <p class="text-xl text-gray-300 font-medium">
        Vi finns här när du behöver oss. Hitta snabba svar eller få personlig hjälp av våra tekniker.
      </p>
    </div>
  </header>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 space-y-24">
    
    <div class="flex justify-center">
      <div class="bg-white p-10 md:p-12 rounded-3xl shadow-lg border border-gray-100 hover:border-sam-cyan hover:shadow-xl transition-all group max-w-2xl w-full text-center flex flex-col items-center">
        <div class="bg-sam-cyan/10 w-20 h-20 rounded-2xl flex items-center justify-center mb-8 text-sam-cyan group-hover:scale-110 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-sam-blue mb-4">Skapa Felanmälan</h2>
        <p class="text-gray-600 mb-8 leading-relaxed max-w-lg">
          Har du stött på ett tekniskt problem i er anläggning? Klicka nedan för att öppna formuläret och beskriva ditt ärende.
        </p>
        <button id="open-form-btn" class="inline-block bg-sam-blue text-white font-bold py-4 px-12 rounded-full hover:bg-sam-cyan transition-colors shadow-md focus:outline-none cursor-pointer">
          Skapa
        </button>
      </div>
    </div>

    <div id="support-form-container" class="hidden max-w-3xl mx-auto bg-white rounded-3xl p-10 md:p-12 border border-gray-100 shadow-2xl scroll-mt-32">
      <div class="border-b border-gray-100 pb-6 mb-8 flex justify-between items-center">
        <div>
          <h2 class="text-3xl font-bold text-sam-blue">Felanmälan</h2>
          <p class="text-sm text-gray-500 mt-1">Vänligen fyll i detaljerna nedan så underlättar det vår felsökning.</p>
        </div>
        <button id="close-form-btn" class="text-gray-400 hover:text-sam-blue transition-colors p-2 rounded-full hover:bg-gray-50 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>

      <form id="support-form" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="company" class="block text-sm font-semibold text-sam-blue mb-2">Företagsnamn *</label>
            <input type="text" id="company" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium" placeholder="T.ex. Företag AB" />
          </div>
          <div>
            <label for="contact" class="block text-sm font-semibold text-sam-blue mb-2">Kontaktperson *</label>
            <input type="text" id="contact" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium" placeholder="För- och efternamn" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="email" class="block text-sm font-semibold text-sam-blue mb-2">E-postadress *</label>
            <input type="email" id="email" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium" placeholder="namn@foretag.se" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-sam-blue mb-2">Telefonnummer</label>
            <input type="tel" id="phone" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium" placeholder="070-000 00 00" />
          </div>
        </div>

        <div>
          <label for="location" class="block text-sm font-semibold text-sam-blue mb-2">Mötesrum / Plats *</label>
          <input type="text" id="location" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium" placeholder="T.ex. Konferensrum Stockholm (Plan 2)" />
        </div>

        <div>
          <label for="description" class="block text-sm font-semibold text-sam-blue mb-2">Beskrivning av felet *</label>
          <textarea id="description" rows="5" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-2xl text-sam-blue focus:outline-none focus:border-sam-cyan focus:ring-2 focus:ring-sam-cyan/20 transition-all font-medium resize-none" placeholder="Beskriv problemet så detaljerat som möjligt (t.ex. 'Ljudet klipper', 'Huvudskärmen startar ej')..."></textarea>
        </div>

        <div class="flex justify-end pt-4">
          <button type="submit" class="bg-sam-blue text-white font-bold py-4 px-12 rounded-full hover:bg-sam-cyan transition-colors shadow-md focus:outline-none w-full md:w-auto cursor-pointer">
            Skicka ärende
          </button>
        </div>
      </form>
    </div>

    <div class="max-w-3xl mx-auto bg-gray-50 rounded-3xl p-10 md:p-16 border border-gray-100 shadow-inner">
      <h2 class="text-3xl font-bold text-sam-blue mb-10 text-center">Vanliga frågor</h2>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-xl font-bold text-sam-blue mb-3">What has ni for inställelsetid på serviceavtal?</h3>
          <p class="text-gray-600">
            För kunder med aktivt serviceavtal (SLA) anpassar vi inställelsetiden helt efter era behov och den kritiska nivån på utrustningen. Kontakta er projektledare för detaljer kring ert specifika avtal.
          </p>
        </div>
        
        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-xl font-bold text-sam-blue mb-3">Skärmen i mötesrummet är svart, vad gör jag?</h3>
          <p class="text-gray-600">
            Börja alltid med att kontrollera att styrsystemet/panelen är vaken och att inga kablar har blivit urdragna ur bordets brunn. Kvarstår problemet, skicka in en felanmälan och ange rumsnamnet tydligt i mejlet.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm">
          <h3 class="text-xl font-bold text-sam-blue mb-3">Tar ni emot serviceärenden från anläggningar ni inte byggt?</h3>
          <p class="text-gray-600">
            Självklart. Med vår djupa expertis inom de flesta styrsystem på marknaden kan vi felsöka, reparera och omprogrammera anläggningar som andra leverantörer har installerat.
          </p>
        </div>
      </div>
    </div>

  </div>
</Layout>

<script>
  const openBtn = document.getElementById('open-form-btn');
  const closeBtn = document.getElementById('close-form-btn');
  const formContainer = document.getElementById('support-form-container');
  const form = document.getElementById('support-form');

  // Öppna och stäng logik
  if (openBtn && closeBtn && formContainer) {
    openBtn.addEventListener('click', () => {
      formContainer.classList.remove('hidden');
      formContainer.scrollIntoView({ behavior: 'smooth' });
    });

    closeBtn.addEventListener('click', () => {
      formContainer.classList.add('hidden');
    });
  }

  // Automatiskt sammanställ mejlet vid klick på Skicka
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const company = document.getElementById('company').value;
      const contact = document.getElementById('contact').value;
      const email = document.getElementById('email').value;
      const phone = document.getElementById('phone').value;
      const location = document.getElementById('location').value;
      const description = document.getElementById('description').value;

      const subject = encodeURIComponent(`Felanmälan: ${company} - ${location}`);
      const body = encodeURIComponent(
        `FELANMÄLAN - SAMTECH AB\n` +
        `=================================\n\n` +
        `Företag: ${company}\n` +
        `Kontaktperson: ${contact}\n` +
        `E-post: ${email}\n` +
        `Telefon: ${phone || 'Ej angivet'}\n` +
        `Plats/Mötesrum: ${location}\n\n` +
        `Beskrivning av problem:\n` +
        `${description}\n\n` +
        `=================================\n` +
        `Skickat via supportformuläret på hemsidan.`
      );

      // Öppnar användarens lokala mejlprogram med all info förifyllt
      window.location.href = `mailto:support@sam-tech.se?subject=${subject}&body=${body}`;
    });
  }
</script>