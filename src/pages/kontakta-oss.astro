---

<Layout>
  <!-- Sidans Header -->
  <header class="bg-sam-blue text-white py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto mt-10">
      <h1 class="text-5xl font-bold mb-6 tracking-tight">Kontakta <span class="text-sam-cyan">Oss</span></h1>
      <p class="text-xl text-gray-300 font-medium">
        Hör av dig direkt till rätt person. Vi ser fram emot att hjälpa er med ert nästa projekt.
      </p>
    </div>
  </header>

  <!-- Huvudinnehåll -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    
    <!-- Allmän kontakt -->
    <div class="text-center mb-16 pb-12 border-b border-gray-200 max-w-2xl mx-auto">
      <p class="text-lg text-gray-600 mb-2">För allmänna frågor eller offertförfrågningar:</p>
      <a href="mailto:info@sam-tech.se" class="text-3xl font-bold text-sam-blue hover:text-sam-cyan transition-colors">info@sam-tech.se</a>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
      
      {team.map((person) => (
        <div class="bg-white rounded-3xl overflow-hidden shadow-lg border border-gray-100 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 group">
          <!-- Profilbild -->
          <div class="aspect-square overflow-hidden relative bg-gray-100">
            <img src={person.img} alt={person.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <!-- Information -->
          <div class="p-6 text-center flex flex-col justify-between h-[200px]">
            <div>
              <h3 class="text-xl font-bold text-sam-blue mb-1">{person.name}</h3>
              <p class="text-sam-cyan font-semibold mb-4 uppercase tracking-wider text-xs">{person.role}</p>
            </div>
            
            <div class="space-y-3 text-gray-600 font-medium text-sm">
              <a href={`mailto:${person.email}`} class="flex items-center justify-center gap-2 hover:text-sam-cyan transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sam-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                {person.email}
              </a>
              <a href={`tel:${person.phoneLink}`} class="flex items-center justify-center gap-2 hover:text-sam-cyan transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sam-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                {person.phone}
              </a>
            </div>
          </div>
        </div>
      ))}

    </div>
  </div>
</Layout>